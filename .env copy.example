# ============================================================
# Intelligent Customer Support Agent — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ----------------------------------------------------------
# REQUIRED
# ----------------------------------------------------------

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Simple API key for endpoint authentication
API_KEY="

# ----------------------------------------------------------
# OPTIONAL — Session & Database
# ----------------------------------------------------------

# Redis for session storage (recommended for production)
# REDIS_URL=redis://localhost:6379/0

# PostgreSQL for tickets, customers, knowledge base
# DATABASE_URL=postgresql://user:password@localhost:5432/support_db

# ----------------------------------------------------------
# OPTIONAL — Email
# ----------------------------------------------------------

# SendGrid (recommended)
# SENDGRID_API_KEY=SG.xxxxx

# OR Mailgun
# MAILGUN_API_KEY=key-xxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com

# From address for outbound emails
SUPPORT_FROM_EMAIL=support@yourdomain.com
SUPPORT_FROM_NAME=Support Team

# ----------------------------------------------------------
# OPTIONAL — Ticketing
# ----------------------------------------------------------

# Zendesk
# ZENDESK_API_KEY=xxxxx
# ZENDESK_SUBDOMAIN=yourcompany

# Webhook secret (for verifying Zendesk / Freshdesk webhooks)
# WEBHOOK_SECRET=your-webhook-secret

# ----------------------------------------------------------
# OPTIONAL — Vector DB (Knowledge Base)
# ----------------------------------------------------------

# Pinecone
# PINECONE_API_KEY=xxxxx
# PINECONE_INDEX=support-kb

# ----------------------------------------------------------
# OPTIONAL — Monitoring
# ----------------------------------------------------------

# OpenTelemetry collector endpoint
# OTLP_ENDPOINT=http://localhost:4317

# Datadog
# DATADOG_ENABLED=false

# ----------------------------------------------------------
# Development
# ----------------------------------------------------------
DEBUG=true
